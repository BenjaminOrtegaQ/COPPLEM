{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "types": ["vite/client"],
    "resolveJsonModule": true,

  },
  "include": ["src", "electron", "src/types", "src/vite-env.d.ts"]
}
