{
  "extends": "../tsconfig.json",
  "include": ["./**/*.ts", "./types/**/*.d.ts"],
  "compilerOptions": {
    "outDir": "../dist-electron",
    "rootDir": ".",
    "module": "CommonJS",
    "target": "ES2022",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node", "electron"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true
    
  }
}
